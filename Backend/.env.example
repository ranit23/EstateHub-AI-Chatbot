# ---------------------------------------------------------------------------
# EstateHub Backend environment variables
# Copy this file to ".env" and fill in your values.
# ---------------------------------------------------------------------------

# Server
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/estatehub

# JWT signing secret (used by routes/auth.js)
ACCESS_TOKEN=replace_with_a_long_random_string

# Cloudinary (image uploads) — optional if you only use image URLs
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------------------------------------------------------------------------
# AI features (OPTIONAL)
# The /api/ai/search and /api/ai/compare endpoints work without any key using
# a built-in rule-based engine. Add a Gemini key to upgrade the parsing and
# generate natural-language summaries.
# Get a key at https://aistudio.google.com/apikey
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
